{
  "manifest_version": 3,
  "name": "Timesheet AutoFill",
  "version": "1.0.0",
  "description": "Tự động điền timesheet hàng tuần với một cú click",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://10.145.48.117:9099/*",
    "http://10.145.48.117/*",
    "https://raw.githubusercontent.com/tuantoquq/internal-timesheet-ext/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://10.145.48.117:9099/*"
      ],
      "js": [
        "popup-core.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
